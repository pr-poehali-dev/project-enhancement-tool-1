{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/?action=register",
      "body": {
        "username": "testuser_vibespace",
        "email": "testuser_vibespace@example.com",
        "password": "password123",
        "displayName": "Test User"
      },
      "expectedStatus": 200,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login user",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "testuser_vibespace@example.com",
        "password": "password123"
      },
      "expectedStatus": 200,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "email": "testuser_vibespace@example.com",
        "password": "wrongpassword"
      },
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}
